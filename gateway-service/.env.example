# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 256 bits (32+ characters). Must match auth-service secret.
JWT_SECRET=change-me-to-a-strong-secret-256-bits-minimum

# ── Service URLs (override for non-Docker environments) ───────────────────────
AUTH_SERVICE_URL=http://auth-service:8081
ACADEMIC_SERVICE_URL=http://academic-service:8082
ROOM_SERVICE_URL=http://room-service:8083
DEFENSE_SERVICE_URL=http://defense-service:8084

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# ── Spring Profile ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=docker
